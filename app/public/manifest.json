{
  "manifest_version": 3,
  "name": "litmus — System Prompt Tester",
  "version": "1.1.0",
  "description": "Test, analyze, and version system prompts against the LLM you ship on. BYOK, local-first, no backend.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/litmus-icon-16.png",
    "32": "icons/litmus-icon-32.png",
    "48": "icons/litmus-icon-48.png",
    "128": "icons/litmus-icon-128.png"
  },
  "action": {
    "default_title": "Open litmus"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"]
}
