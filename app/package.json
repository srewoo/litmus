{
  "name": "litmus-extension",
  "private": true,
  "version": "1.4",
  "type": "module",
  "description": "litmus — iterative system-prompt testing, in-console (BYOK)",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/ui/sidepanel.ts --bundle --format=iife --outfile=public/sidepanel.js --target=chrome116 --log-level=warning",
    "build:watch": "npm run build -- --watch",
    "package": "npm run build && rm -f litmus-extension-$npm_package_version.zip && cd public && zip -r -X ../litmus-extension-$npm_package_version.zip . -x '.*' '*/.*' && cd .. && echo \"Packaged litmus-extension-$npm_package_version.zip\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}